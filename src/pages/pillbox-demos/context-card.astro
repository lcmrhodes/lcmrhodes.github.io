---
import Layout from '../../layouts/Layout.astro';
import PillboxDemoLayout from '../../components/PillboxDemoLayout.astro';
import '../../styles/pillbox-demos.css';

const viewports = [
	{ label: 'Desktop', width: '1120px', className: 'preview-window--wide' },
	{ label: 'Tablet', width: '760px', className: 'preview-window--medium' },
	{ label: 'Phone', width: '390px', className: 'preview-window--narrow' },
];
---

<Layout
	title="Context Card Pillbox Demo | Luke Rhodes"
	description="Responsive pillbox demo where the capsule becomes a compact card on smaller widths."
>
	<PillboxDemoLayout
		current="context-card"
		kicker="Direction three"
		title="Priority collapse"
		description="This keeps the same pill shape, but on the smallest widths it hides the least important actions behind one compact more button so the control stays short."
		bestFor="Keeping the mobile footprint smallest."
		tradeoff="One extra tap is needed to reach hidden actions if you later implement a drawer or menu."
	>
		<section class="preview-grid">
			{viewports.map((viewport) => (
				<article class="preview-card">
					<div class="preview-card-head">
						<p class="preview-card-label">{viewport.label}</p>
						<span class="preview-card-size">{viewport.width}</span>
					</div>

					<div class:list={['preview-window', viewport.className]}>
						<div class="preview-app">
							<p class="pillbox-stage-copy">On phone widths, lower-priority actions collapse into one small overflow trigger.</p>

							<div class="pillbox-shell variant-collapse">
								<div class="pillbox-group">
									<button class="pillbox-control" type="button" aria-label="GitHub">GH</button>
									<button class="pillbox-control" type="button" aria-label="LinkedIn">in</button>
									<button class="pillbox-control pillbox-control--label" type="button" aria-label="Curriculum vitae">CV</button>
									<button class="pillbox-control" type="button" aria-label="Email">@</button>
								</div>
								<div class="pillbox-divider" aria-hidden="true"></div>
								<div class="pillbox-group">
									<button class="pillbox-control pillbox-control--optional" type="button" aria-label="Sound">snd</button>
									<button class="pillbox-control pillbox-control--optional" type="button" aria-label="Weather">wx</button>
									<button class="pillbox-control is-active" type="button" aria-label="Theme">sun</button>
									<button class="pillbox-control pillbox-control--more" type="button" aria-label="More actions">+</button>
								</div>
							</div>
						</div>
					</div>
				</article>
			))}
		</section>
	</PillboxDemoLayout>
</Layout>
