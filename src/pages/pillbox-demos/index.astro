---
import Layout from '../../layouts/Layout.astro';
import '../../styles/pillbox-demos.css';

const demos = [
	{
		title: 'Elastic wrap',
		slug: 'adaptive-rail',
		tagline: 'Keep the same pill, but let it wrap and tighten gracefully at smaller widths.',
		bestFor: 'Closest to what you already have.',
	},
	{
		title: 'Two-tier stack',
		slug: 'split-dock',
		tagline: 'Same object, but it turns into two neat rows on smaller viewports.',
		bestFor: 'Cleanest if you want more structure without changing the look too much.',
	},
	{
		title: 'Priority collapse',
		slug: 'context-card',
		tagline: 'The pill stays compact by hiding lower-priority actions behind a single more button on phones.',
		bestFor: 'Best if you want the smallest mobile footprint.',
	},
];
---

<Layout
	title="Pillbox Demo Options | Luke Rhodes"
	description="Three separate pillbox demos exploring more dynamic responsive behavior."
>
	<div class="pillbox-demo-page">
		<header class="pillbox-demo-topbar">
			<a class="pillbox-demo-backlink" href="/">Back to homepage</a>
		</header>

		<main class="pillbox-demo-main">
			<section class="pillbox-demo-intro">
				<p class="pillbox-demo-kicker">Tighter scope</p>
				<h1>Three direct variants of just the little pill control.</h1>
				<p class="pillbox-demo-description">
					These pages only change the small rounded icon cluster. No broader layout ideas, no alternate page structure.
				</p>
			</section>

			<section class="pillbox-demo-index-grid" aria-label="Pillbox demo variants">
				{demos.map((demo) => (
					<article class="pillbox-demo-index-card">
						<p class="pillbox-demo-kicker">{demo.title}</p>
						<h2>{demo.tagline}</h2>
						<p>{demo.bestFor}</p>
						<div class="pillbox-demo-index-actions">
							<a class="pillbox-demo-index-link" href={`/pillbox-demos/${demo.slug}/`}>Open demo</a>
						</div>
					</article>
				))}
			</section>
		</main>
	</div>
</Layout>
