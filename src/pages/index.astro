							<li class={`gallery-tile gallery-tile--${tile.kind}`}>
								{tile.kind === 'image' ? (
									<button
										type="button"
										class="gallery-tile__action"
										data-lightbox-src={tile.full}
										data-lightbox-width={String(tile.fullWidth)}
										data-lightbox-height={String(tile.fullHeight)}
										data-lightbox-alt={tile.title}
										data-lightbox-caption={tile.caption}
										aria-label={`${tile.title} — open full image`}
									>
										<figure>
											<img
												src={tile.cover}
												width={tile.coverWidth}
												height={tile.coverHeight}
												alt={tile.title}
												loading="lazy"
												decoding="async"
											/>
											<figcaption class="gallery-tile__overlay">
												<span class="gallery-tile__eyebrow">{tile.eyebrow}</span>
												<span class="gallery-tile__title">{tile.title}</span>
												<span class="gallery-tile__caption">{tile.caption}</span>
											</figcaption>
										</figure>
									</button>
								) : (
									<a
										href={tile.href}
										class="gallery-tile__action"
										target={tile.kind === 'site' ? '_blank' : undefined}
										rel={tile.kind === 'site' ? 'noreferrer' : undefined}
										aria-label={`${tile.title} — ${tile.kind === 'site' ? 'open live site' : 'open PDF'}`}
									>
										<figure>
											<img
												src={tile.cover}
												width={tile.coverWidth}
												height={tile.coverHeight}
												alt={tile.title}
												loading="lazy"
												decoding="async"
											/>
											<figcaption class="gallery-tile__overlay">
												<span class="gallery-tile__eyebrow">{tile.eyebrow}</span>
												<span class="gallery-tile__title">{tile.title}</span>
												<span class="gallery-tile__caption">{tile.caption}</span>
											</figcaption>
										</figure>
									</a>
								)}
							</li>
						))}
					</ul>

					<dialog class="gallery-lightbox" id="gallery-lightbox" aria-label="Image viewer">
						<button type="button" class="gallery-lightbox__close" aria-label="Close image viewer">&#x2715;</button>
						<figure>
							<img alt="" />
							<figcaption></figcaption>
						</figure>
					</dialog>
				</div>

				<script>
					const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
					if (dialog) {
						const lightboxImg = dialog.querySelector('img') as HTMLImageElement;
						const lightboxCaption = dialog.querySelector('figcaption') as HTMLElement;
						const closeBtn = dialog.querySelector('.gallery-lightbox__close') as HTMLButtonElement;

						// Open on click of any lightbox trigger
						document.querySelector('.project-gallery')?.addEventListener('click', (e) => {
							const btn = (e.target as Element).closest('[data-lightbox-src]') as HTMLElement | null;
							if (!btn) return;
							const src = btn.dataset.lightboxSrc ?? '';
							const w = Number(btn.dataset.lightboxWidth ?? 0);
							const h = Number(btn.dataset.lightboxHeight ?? 0);
							const alt = btn.dataset.lightboxAlt ?? '';
							const caption = btn.dataset.lightboxCaption ?? '';
							lightboxImg.src = src;
							lightboxImg.width = w;
							lightboxImg.height = h;
							lightboxImg.alt = alt;
							lightboxCaption.textContent = caption;
							dialog.showModal();
						});

						// Close via button
						closeBtn?.addEventListener('click', () => {
							dialog.close();
						});

						// Close via backdrop click
						dialog.addEventListener('click', (e) => {
							if (e.target === dialog) dialog.close();
						});

						// Clear src on close to free the large PNG from memory
						dialog.addEventListener('close', () => {
							lightboxImg.src = '';
							lightboxImg.alt = '';
							lightboxCaption.textContent = '';
						});
					}
				</script>
