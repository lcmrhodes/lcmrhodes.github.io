---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProjectLane from '../components/ProjectLane.astro';
import '../styles/global.css';

const tabs = ['about', 'experience', 'projects'];

const projects = (await getCollection('projects')).sort((a, b) => a.data.rank - b.data.rank);

const lanes = [
	{
		key: 'visualization',
		title: 'Visualisation & Storytelling',
		subtitle: 'Interactive work that turns data, systems, and relationships into something people can actually feel.',
	},
	{
		key: 'product',
		title: 'Recommendation & Product Systems',
		subtitle: 'Interfaces and tools where user flow, taste, and decision logic matter as much as implementation.',
	},
	{
		key: 'research',
		title: 'Research & Health Systems',
		subtitle: 'Modeling, APIs, and decision-support tooling built for serious operational or analytical contexts.',
	},
];

const laneProjects = lanes.map((lane) => ({
	...lane,
	projects: projects.filter((project) => project.data.lane === lane.key),
}));

const experienceItems = [
	{
		title: 'MORU',
		label: 'Research Consultant',
		body: 'Building deployment-ready pediatric triage and decision-support tooling for low-resource health contexts.',
		link: { label: 'Contributing author — JMIR preprint 2025 ↗', url: 'https://preprints.jmir.org/preprint/97395' },
	},
	{
		title: 'University of Oxford',
		label: 'MSc, Modelling for Global Health',
		body: 'Distinction-level training in modeling, applied health analysis, and research systems.',
		link: { label: 'Genetics essay (PDF) ↓', url: '/papers/genetics_essay.pdf' },
	},
	{
		title: 'UCL',
		label: 'Population Health & Data Science',
		body: 'Population Health degree plus dashboard and reporting work for the UCL Institute of Education.',
		link: { label: 'Undergraduate dissertation (PDF) ↓', url: '/papers/undergraduate_dissertation.pdf' },
	},
	{
		title: 'Population Health Sciences Magazine',
		label: 'Graphical Design Editor',
		body: 'Directed visual strategy and design delivery across print and digital publication work.',
		link: null,
	},
];

const featuredProjects = projects.filter((project) => project.data.featured);

const galleryItems = [
	{ type: 'image', src: '/images/gallery/tolkien_thumb.jpg', title: 'Tolkien Constellation', caption: "Narrative dataviz mapping Tolkien's world — coursework piece", fullRes: '/images/gallery/tolkien_full.png', hero: true },
	{ type: 'image', src: '/images/gallery/bookmaker_map.jpg', title: 'Bookmaker Density Map', caption: 'Combined spatial output from gambling harm analysis' },
	{ type: 'image', src: '/images/gallery/morans_map.jpg', title: "Multi-Health Moran's I", caption: 'Spatial autocorrelation across deprivation indices' },
	{ type: 'image', src: '/images/gallery/neighbour_map.jpg', title: 'Neighbourhood Structure', caption: 'Spatial weights and adjacency — analysis context map' },
	{ type: 'image', src: '/images/gallery/design_principles_map.jpg', title: 'Design Principles Map', caption: 'Cartographic coursework, group project' },
	{ type: 'pdf', src: '/papers/phs_magazine_pages.pdf', title: 'PHS Magazine pp.30–38', caption: 'Spreads from the Population Health Sciences Magazine' },
	{ type: 'pdf', src: '/papers/oregon_dunes.pdf', title: 'Oregon Dunes', caption: 'Geographic documentation piece' },
	{ type: 'pdf', src: '/papers/invitation_template.pdf', title: 'Invitation Template', caption: 'Print design — personalised invitation system' },
];
---

<Layout
	title="Luke Rhodes | Visualisation, Product, and Research Software"
	description="Interactive visualisations, recommendation tools, and research software by Luke Rhodes."
>
	<div class="layout" data-active-tab="about">

		<!-- ── Left: fixed identity panel ─────────────────────── -->
		<aside class="identity-panel">
			<div class="identity-top">
				<h1 class="identity-name anim-entrance" data-delay="0">Luke Rhodes</h1>
				<p class="identity-tagline anim-entrance" data-delay="1">Visualisation, product, and research software.</p>
			</div>

			<div class="about-portrait-placeholder">
				<img class="about-portrait-image about-portrait-image--light" src="/images/luke-portrait.jpg" alt="Portrait of Luke Rhodes" />
				<img class="about-portrait-image about-portrait-image--dark" src="/images/luke-portrait-dark.png" alt="Portrait of Luke Rhodes" />
			</div>

			<nav class="side-nav" aria-label="Site sections">
				{tabs.map((tab) => (
					<button
						class:list={['side-nav-item', 'anim-entrance', { active: tab === 'about' }]}
						data-delay="3"
						data-tab={tab}
						type="button"
						aria-current={tab === 'about' ? 'page' : 'false'}
					>
						{tab.charAt(0).toUpperCase() + tab.slice(1)}
					</button>
				))}
				<span class="side-nav-indicator" aria-hidden="true"></span>
			</nav>

			<div class="identity-bottom anim-entrance" data-delay="4">
				<div class="identity-links">
					<a href="https://github.com/lcmrhodes" target="_blank" rel="noreferrer">GitHub</a>
					<a href="https://www.linkedin.com/in/lukecmrhodes" target="_blank" rel="noreferrer">LinkedIn</a>
					<a href="/Luke_Rhodes_CV_2025.docx">CV</a>
					<a href="mailto:lcmrhodes98@gmail.com">Email</a>
				</div>
				<div class="identity-controls">
					<button class="sound-toggle-side" type="button" data-sound-toggle aria-label="Mute sounds">
						<svg class="sound-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path class="sound-icon-speaker" d="M11 5 6 9H3v6h3l5 4V5z"></path>
							<path class="sound-icon-wave sound-icon-wave--inner" d="M15.5 9.5a4 4 0 0 1 0 5"></path>
							<path class="sound-icon-wave sound-icon-wave--outer" d="M18.5 7a8 8 0 0 1 0 10"></path>
							<path class="sound-icon-mute" d="m15 9 6 6"></path>
							<path class="sound-icon-mute" d="m21 9-6 6"></path>
						</svg>
						<span class="sound-toggle-label">Sound on</span>
					</button>
					<button class="theme-toggle-side" type="button" data-theme-toggle aria-label="Dark mode">
						<svg class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<circle class="theme-icon-sun" cx="12" cy="12" r="5"></circle>
							<g class="theme-icon-rays">
								<line x1="12" y1="1" x2="12" y2="3"></line>
								<line x1="12" y1="21" x2="12" y2="23"></line>
								<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
								<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
								<line x1="1" y1="12" x2="3" y2="12"></line>
								<line x1="21" y1="12" x2="23" y2="12"></line>
								<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
								<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
							</g>
							<path class="theme-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
						</svg>
						<span class="theme-toggle-label">Dark mode</span>
					</button>
				</div>
			</div>
		</aside>

		<!-- ── Right: switchable content panel ───────────────── -->
		<main class="content-panel" id="content-panel">

			<!-- About -->
			<section class="content-section active" data-section="about" id="tab-about" aria-hidden="false">
				<div class="content-section-inner">
					<div class="section-intro about-hero">
						<h2 class="anim-entrance" data-delay="3">Hi, I'm Luke.</h2>
						<p class="anim-entrance about-summary" data-delay="4">
							<span class="about-summary-lead">
								I turn information into products that make decisions easier.
							</span>
							<span class="about-summary-detail">
								From a <a
									href="https://sepsis-flow-web-app.onrender.com"
									target="_blank"
									rel="noreferrer"
									class="about-inline-link about-inline-link--pulse"
								><span class="about-inline-link-text">clinical decision-support tool</span></a> to a <a
									href="https://myscenttaste.vercel.app"
									class="about-inline-link about-inline-link--fragrance"
								><span class="about-inline-link-text">taste-led fragrance profiling app</span></a> and an <a
									href="https://wedding-network.vercel.app"
									target="_blank"
									rel="noreferrer"
									class="about-inline-link about-inline-link--wedding"
								><span class="about-inline-link-text">interactive wedding network</span><span class="about-inline-link__sparkles" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></span></a> built as part of my own invitations, I like making
								things that work well and look right.
							</span>
						</p>
					</div>
				</div>
			</section>

			<!-- Experience -->
			<section class="content-section" data-section="experience" id="tab-experience">
				<div class="content-section-inner proof-grid">
					<div class="section-intro section-intro-wide">
						<p class="eyebrow" data-number="02">Experience</p>
						<h2>A few of the places and roles shaping how I build.</h2>
						<p>
							Research, product thinking, and visual work have all fed into the way I
							approach software.
						</p>
					</div>

					<div class="proof-cards">
						{experienceItems.map((item) => (
							<article class="proof-card">
								<p class="proof-title">{item.title}</p>
								<h3>{item.label}</h3>
								<p>{item.body}</p>
								{item.link && (
									<a href={item.link.url} target="_blank" rel="noreferrer" class="proof-link">
										{item.link.label}
									</a>
								)}
							</article>
						))}
					</div>
				</div>
			</section>

			<!-- Projects -->
			<section class="content-section" data-section="projects" id="tab-projects">
				<div class="content-section-inner work-stack">
					<div class="section-intro section-intro-wide">
						<p class="eyebrow" data-number="03">Projects</p>
						<h2>The projects at the core of the site.</h2>
						<p>
							Work grouped by capability. The flagship trio is
							<strong>WeddingNetwork</strong>, <strong>ScentSense</strong>, and
							<strong>Sepsis Flow</strong>.
						</p>
					</div>

					<div class="featured-strip" aria-label="Flagship projects">
						{featuredProjects.map((project) => (
							<article class="featured-card">
								<p class="featured-label">{project.data.lane}</p>
								<h3>{project.data.title}</h3>
								<p>{project.data.summary}</p>
								<div class="featured-links">
									<a href={`/projects/${project.id}/`}>Read case study</a>
									{project.data.liveUrl && (
										<a href={project.data.liveUrl} target="_blank" rel="noreferrer">Live</a>
									)}
									{project.data.papers && project.data.papers.map((paper) => (
										<a href={paper.url} target="_blank" rel="noreferrer">↓ {paper.label}</a>
									))}
								</div>
							</article>
						))}
					</div>

					{laneProjects.map((lane) => (
						<ProjectLane
							title={lane.title}
							subtitle={lane.subtitle}
							projects={lane.projects}
						/>
					))}
				</div>
			</section>

		</main>
	</div>

	<!-- Mobile top bar (shown only on small screens) -->
	<header class="mobile-header">
		<span class="mobile-name">Luke Rhodes</span>
		<button class="mobile-nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
			<span class="mobile-nav-toggle-bar"></span>
			<span class="mobile-nav-toggle-bar"></span>
			<span class="mobile-nav-toggle-bar"></span>
		</button>
	</header>
	<nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
		{tabs.map((tab) => (
			<button
				class:list={['mobile-nav-item', { active: tab === 'about' }]}
				data-tab={tab}
				type="button"
				aria-current={tab === 'about' ? 'page' : 'false'}
			>
				{tab.charAt(0).toUpperCase() + tab.slice(1)}
			</button>
		))}
		<div class="identity-controls identity-controls--mobile">
			<button class="sound-toggle-side sound-toggle-side--mobile" type="button" data-sound-toggle aria-label="Mute sounds">
				<svg class="sound-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path class="sound-icon-speaker" d="M11 5 6 9H3v6h3l5 4V5z"></path>
					<path class="sound-icon-wave sound-icon-wave--inner" d="M15.5 9.5a4 4 0 0 1 0 5"></path>
					<path class="sound-icon-wave sound-icon-wave--outer" d="M18.5 7a8 8 0 0 1 0 10"></path>
					<path class="sound-icon-mute" d="m15 9 6 6"></path>
					<path class="sound-icon-mute" d="m21 9-6 6"></path>
				</svg>
				<span class="sound-toggle-label">Sound on</span>
			</button>
			<button class="theme-toggle-side theme-toggle-side--mobile" type="button" data-theme-toggle aria-label="Dark mode">
				<svg class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<circle class="theme-icon-sun" cx="12" cy="12" r="5"></circle>
					<g class="theme-icon-rays">
						<line x1="12" y1="1" x2="12" y2="3"></line>
						<line x1="12" y1="21" x2="12" y2="23"></line>
						<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
						<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
						<line x1="1" y1="12" x2="3" y2="12"></line>
						<line x1="21" y1="12" x2="23" y2="12"></line>
						<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
						<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
					</g>
					<path class="theme-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
				<span class="theme-toggle-label">Dark mode</span>
			</button>
		</div>
	</nav>

	<script>
		import initPortfolioInteractions from '../scripts/interactions';

		initPortfolioInteractions();
	</script>
</Layout>
