---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { galleryTiles } from '../data/gallery';

const tabs = ['about', 'experience', 'projects'];

const professionalExperienceItems = [
	{
		title: 'MORU',
		label: 'Research Consultant',
		dates: '2025 – Present',
		location: 'Remote / Bangkok',
		body: 'Leading development and deployment of a machine learning–driven clinical triage tool for paediatric febrile illness in low-resource settings.',
		logoLight: '/images/moro_logo_light.svg',
		logoDark: '/images/moro_logo_dark.svg',
		logoAlt: 'Mahidol-Oxford Tropical Medicine Research Unit logo',
		logoClass: 'experience-brand-logo--moru',
		links: [
			{ label: 'Preprint — JMIR 2025 ↗', url: 'https://preprints.jmir.org/preprint/97395' },
			{ label: 'Sepsis Flow (live) ↗', url: 'https://sepsis-flow-web-app.onrender.com' },
		],
	},
	{
		title: 'Population Health Sciences Magazine',
		label: 'Graphical Design Editor',
		dates: 'Feb. 2024 – May 2024',
		location: 'London',
		body: 'Led visual identity and editorial graphics, translating complex research into clear, publication-ready visual systems.',
		logoLight: '/images/pop_health_mag_logo_light.svg',
		logoDark: '/images/pop_health_mag_logo_dark.svg',
		logoAlt: 'Population Health Sciences Magazine logo',
		logoClass: 'experience-brand-logo--phs',
		links: [
			{ label: 'My contributions (PDF) ↓', url: '/papers/phs_magazine_pages.pdf' },
		],
	},
	{
		title: 'Deliveroo',
		label: 'Store Developer',
		dates: 'Sept. 2023',
		location: 'Remote',
		body: 'Designed and launched a full online storefront, structuring product data, pricing, and catalogue logic across 300+ items.',
		logoLight: '/images/deliveroo_logo_light.svg',
		logoDark: '/images/deliveroo_logo_dark.svg',
		logoAlt: 'Deliveroo logo',
		logoClass: 'experience-brand-logo--deliveroo',
		links: [],
	},
	{
		title: 'Boots UK',
		label: 'Pharmacy Advisor / Dispenser',
		dates: 'Feb. 2017 – Jan. 2022',
		location: 'Malvern & London',
		body: 'Delivered frontline pharmacy services including dispensing, vaccinations, and patient support within high-volume clinical settings.',
		logoLight: '/images/boots_logo_light.svg',
		logoDark: '/images/boots_logo_dark.svg',
		logoAlt: 'Boots logo',
		logoClass: 'experience-brand-logo--boots',
		links: [],
	},
];

const educationExperienceItems = [
	{
		title: 'University of Oxford',
		label: 'MSc Modelling for Global Health',
		awarded: 'Distinction (~3.9 GPA)',
		dates: '2024 – 2025',
		location: 'Oxford',
		body: 'Trained in statistical and computational modelling for global health, focusing on infectious disease dynamics, machine learning, and decision-support systems.',
		logoLight: '/images/oxford_logo_light.svg',
		logoDark: '/images/oxford_logo_dark.svg',
		logoAlt: 'University of Oxford logo',
		logoClass: 'experience-brand-logo--oxford',
		links: [
			{ label: 'Dissertation preview (pp. 1–2) ↓ — contact for full', url: '/papers/oxford_dissertation_preview.pdf' },
		],
	},
	{
		title: 'University College London',
		label: 'BSc Population Health Sciences (Data Science)',
		awarded: 'Upper Second Class Hons (~3.7 GPA)',
		dates: '2021 – 2024',
		location: 'London',
		body: 'Studied epidemiology and health data science, culminating in a dissertation applying IRT and regression to model medication burden and illness.',
		logoLight: '/images/ucl_logo_light.svg',
		logoDark: '/images/ucl_logo_dark.svg',
		logoAlt: 'University College London logo',
		logoClass: 'experience-brand-logo--ucl',
		links: [
			{ label: 'Dissertation preview (pp. 1–2) ↓ — contact for full', url: '/papers/ucl_dissertation_preview.pdf' },
		],
	},
];


---

<Layout
	title="Luke Rhodes | Visualisation, Product, and Research Software"
	description="Interactive visualisations, recommendation tools, and research software by Luke Rhodes."
>
	<div class="layout" data-active-tab="about">
		<canvas id="weather-canvas" aria-hidden="true"></canvas>
		<div id="weather-clouds" aria-hidden="true"></div>

		<!-- ── Left: fixed identity panel ─────────────────────── -->
		<aside class="identity-panel">
			<div class="identity-top">
				<h1 class="identity-name anim-entrance" data-delay="0">Luke Rhodes</h1>
				<p class="identity-tagline anim-entrance" data-delay="1">Data science, analytics, and real-world tools.</p>
			</div>

				<div class="about-portrait-placeholder">
					<img class="about-portrait-image about-portrait-image--light" src="/images/luke-portrait.jpg" alt="Portrait of Luke Rhodes" loading="eager" decoding="sync" fetchpriority="high" />
					<img class="about-portrait-image about-portrait-image--dark" src="/images/luke-portrait-dark.png" alt="" aria-hidden="true" loading="eager" decoding="sync" fetchpriority="high" />
				</div>

			<nav class="side-nav" aria-label="Site sections">
				{tabs.map((tab) => (
					<button
						class:list={['side-nav-item', 'anim-entrance', { active: tab === 'about' }]}
						data-delay="3"
						data-tab={tab}
						type="button"
						aria-current={tab === 'about' ? 'page' : 'false'}
					>
						{tab.charAt(0).toUpperCase() + tab.slice(1)}
					</button>
				))}
				<span class="side-nav-indicator" aria-hidden="true"></span>
			</nav>

			<div class="identity-bottom anim-entrance" data-delay="4">
				<div class="identity-links">
					<a
						class="identity-link-icon"
						href="https://github.com/lcmrhodes"
						target="_blank"
						rel="noreferrer"
						aria-label="GitHub"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.92.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.68 1.25 3.33.96.1-.74.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.72 0-1.27.45-2.31 1.18-3.13-.12-.29-.51-1.48.11-3.08 0 0 .97-.31 3.17 1.2a10.99 10.99 0 0 1 5.77 0c2.2-1.51 3.17-1.2 3.17-1.2.63 1.6.24 2.79.12 3.08.73.82 1.18 1.86 1.18 3.13 0 4.45-2.69 5.42-5.26 5.71.41.35.78 1.04.78 2.11 0 1.53-.01 2.76-.01 3.13 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"></path>
						</svg>
						<span class="sr-only">GitHub</span>
					</a>
					<a
						class="identity-link-icon"
						href="https://www.linkedin.com/in/lukecmrhodes"
						target="_blank"
						rel="noreferrer"
						aria-label="LinkedIn"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M4.98 3.5A2.48 2.48 0 1 0 5 8.46 2.48 2.48 0 0 0 4.98 3.5zM3 9h4v12H3zM10 9h3.83v1.64h.05c.53-1.01 1.84-2.08 3.79-2.08 4.05 0 4.8 2.66 4.8 6.12V21h-4v-5.63c0-1.34-.02-3.07-1.87-3.07-1.88 0-2.17 1.47-2.17 2.97V21h-4z"></path>
						</svg>
						<span class="sr-only">LinkedIn</span>
					</a>
					<a class="identity-link-icon" href="/Luke_Rhodes_CV_2025.docx" aria-label="Download CV">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
							<path d="M14 2v5h5"></path>
							<path d="M8.5 13h7"></path>
							<path d="M8.5 17h5"></path>
						</svg>
						<span class="sr-only">Download CV</span>
					</a>
					<a class="identity-link-icon" href="mailto:lcmrhodes98@gmail.com" aria-label="Email Luke Rhodes">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="3" y="5" width="18" height="14" rx="2"></rect>
							<path d="m4 7 8 6 8-6"></path>
						</svg>
						<span class="sr-only">Email Luke Rhodes</span>
					</a>
				</div>
				<div class="identity-controls">
					<button class="sound-toggle-side" type="button" data-sound-toggle aria-label="Mute sounds">
						<svg class="sound-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path class="sound-icon-speaker" d="M11 5 6 9H3v6h3l5 4V5z"></path>
							<path class="sound-icon-wave sound-icon-wave--inner" d="M15.5 9.5a4 4 0 0 1 0 5"></path>
							<path class="sound-icon-wave sound-icon-wave--outer" d="M18.5 7a8 8 0 0 1 0 10"></path>
							<path class="sound-icon-mute" d="m15 9 6 6"></path>
							<path class="sound-icon-mute" d="m21 9-6 6"></path>
						</svg>
					</button>
					<button class="weather-toggle-side" type="button" data-weather-toggle aria-label="Weather: off">
						<svg class="weather-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<!-- off: cloud outline -->
							<path class="weather-icon-off" d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
							<!-- rain: cloud + drops -->
							<g class="weather-icon-rain">
								<path d="M20 17.58A5 5 0 0 0 18 8h-1.26A8 8 0 1 0 4 16.25"></path>
								<line x1="8" y1="19" x2="8" y2="21"></line>
								<line x1="8" y1="23" x2="8" y2="25"></line>
								<line x1="12" y1="18" x2="12" y2="20"></line>
								<line x1="12" y1="22" x2="12" y2="24"></line>
								<line x1="16" y1="19" x2="16" y2="21"></line>
								<line x1="16" y1="23" x2="16" y2="25"></line>
							</g>
							<!-- clouds: sun + cloud -->
							<g class="weather-icon-clouds">
								<path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2M4.93 19.07l1.41-1.41M8 13a4 4 0 0 1 4-4"></path>
								<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
							</g>
							<!-- snow: snowflake -->
							<g class="weather-icon-snow">
								<line x1="12" y1="2" x2="12" y2="22"></line>
								<path d="m20 6-8 6-8-6"></path>
								<path d="m4 18 8-6 8 6"></path>
								<line x1="2" y1="12" x2="22" y2="12"></line>
								<path d="m20 18-8-6-8 6"></path>
								<path d="m4 6 8 6 8-6"></path>
							</g>
							<!-- overcast: filled cloud -->
							<g class="weather-icon-overcast">
								<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
								<path d="M6 20h12" stroke-linecap="round"></path>
							</g>
						</svg>
					</button>
					<button class="theme-toggle-side" type="button" data-theme-toggle aria-label="Dark mode">
						<svg class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<circle class="theme-icon-sun" cx="12" cy="12" r="5"></circle>
							<g class="theme-icon-rays">
								<line x1="12" y1="1" x2="12" y2="3"></line>
								<line x1="12" y1="21" x2="12" y2="23"></line>
								<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
								<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
								<line x1="1" y1="12" x2="3" y2="12"></line>
								<line x1="21" y1="12" x2="23" y2="12"></line>
								<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
								<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
							</g>
							<path class="theme-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
						</svg>
					</button>
					<div class="pillbox-overflow">
						<button
							class="pillbox-overflow-toggle"
							type="button"
							data-pillbox-overflow-toggle
							aria-label="More controls"
							aria-expanded="false"
							aria-controls="identity-pillbox-overflow-menu"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
								<circle cx="5" cy="12" r="1.35"></circle>
								<circle cx="12" cy="12" r="1.35"></circle>
								<circle cx="19" cy="12" r="1.35"></circle>
							</svg>
						</button>
						<div
							class="pillbox-overflow-menu"
							id="identity-pillbox-overflow-menu"
							data-pillbox-overflow-menu
							aria-hidden="true"
						>
							<button class="sound-toggle-side pillbox-overflow-action pillbox-overflow-action--sound" type="button" data-sound-toggle aria-label="Mute sounds">
								<svg class="sound-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path class="sound-icon-speaker" d="M11 5 6 9H3v6h3l5 4V5z"></path>
									<path class="sound-icon-wave sound-icon-wave--inner" d="M15.5 9.5a4 4 0 0 1 0 5"></path>
									<path class="sound-icon-wave sound-icon-wave--outer" d="M18.5 7a8 8 0 0 1 0 10"></path>
									<path class="sound-icon-mute" d="m15 9 6 6"></path>
									<path class="sound-icon-mute" d="m21 9-6 6"></path>
								</svg>
							</button>
							<button class="weather-toggle-side pillbox-overflow-action" type="button" data-weather-toggle aria-label="Weather: off">
								<svg class="weather-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path class="weather-icon-off" d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
									<g class="weather-icon-rain">
										<path d="M20 17.58A5 5 0 0 0 18 8h-1.26A8 8 0 1 0 4 16.25"></path>
										<line x1="8" y1="19" x2="8" y2="21"></line>
										<line x1="8" y1="23" x2="8" y2="25"></line>
										<line x1="12" y1="18" x2="12" y2="20"></line>
										<line x1="12" y1="22" x2="12" y2="24"></line>
										<line x1="16" y1="19" x2="16" y2="21"></line>
										<line x1="16" y1="23" x2="16" y2="25"></line>
									</g>
									<g class="weather-icon-clouds">
										<path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2M4.93 19.07l1.41-1.41M8 13a4 4 0 0 1 4-4"></path>
										<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
									</g>
									<g class="weather-icon-snow">
										<line x1="12" y1="2" x2="12" y2="22"></line>
										<path d="m20 6-8 6-8-6"></path>
										<path d="m4 18 8-6 8 6"></path>
										<line x1="2" y1="12" x2="22" y2="12"></line>
										<path d="m20 18-8-6-8 6"></path>
										<path d="m4 6 8 6 8-6"></path>
									</g>
									<g class="weather-icon-overcast">
										<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
										<path d="M6 20h12" stroke-linecap="round"></path>
									</g>
								</svg>
							</button>
							<button class="theme-toggle-side pillbox-overflow-action" type="button" data-theme-toggle aria-label="Dark mode">
								<svg class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<circle class="theme-icon-sun" cx="12" cy="12" r="5"></circle>
									<g class="theme-icon-rays">
										<line x1="12" y1="1" x2="12" y2="3"></line>
										<line x1="12" y1="21" x2="12" y2="23"></line>
										<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
										<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
										<line x1="1" y1="12" x2="3" y2="12"></line>
										<line x1="21" y1="12" x2="23" y2="12"></line>
										<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
										<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
									</g>
									<path class="theme-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
								</svg>
							</button>
						</div>
					</div>
				</div>
			</div>
		</aside>

		<!-- ── Right: switchable content panel ───────────────── -->
		<main class="content-panel" id="content-panel">

			<!-- About -->
			<section class="content-section active" data-section="about" id="tab-about" aria-hidden="false">
				<div class="content-section-inner">
					<div class="section-intro about-hero">
						<h2><span class="about-heading-chunk">Hi,</span><span class="about-heading-chunk"> I'm Luke.</span></h2>
						<p class="about-summary">
							<span class="about-summary-lead">
								I turn information into products that make decisions easier.
							</span>
							<span class="about-summary-detail">
								<span class="about-summary-chunk">
									<span class="about-summary-fragment">From a </span><a
										href="https://sepsis-flow-web-app.onrender.com"
										target="_blank"
										rel="noreferrer"
										class="about-inline-link about-inline-link--pulse"
									><span class="about-inline-link-text">clinical decision-support tool</span></a>
								</span>
								<span class="about-summary-chunk">
									<span class="about-summary-fragment"> to a </span><a
										href="https://myscenttaste.vercel.app"
										class="about-inline-link about-inline-link--fragrance"
									><span class="about-inline-link-text">taste-led fragrance profiling app</span></a><span class="about-summary-fragment">,</span>
								</span>
								<span class="about-summary-chunk">
									<span class="about-summary-fragment"> and an </span><a
										href="https://wedding-network.vercel.app"
										target="_blank"
										rel="noreferrer"
										class="about-inline-link about-inline-link--wedding"
									><span class="about-inline-link-text">interactive wedding network</span><span class="about-inline-link__sparkles" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></span></a><span class="about-summary-fragment"> built as part of my own invitations,</span>
								</span>
								<span class="about-summary-chunk">
									<span class="about-summary-fragment"> I like making things that work well and look right.</span>
								</span>
							</span>
						</p>
					</div>
				</div>
			</section>

			<!-- Experience -->
			<section class="content-section" data-section="experience" id="tab-experience">
				<div class="content-section-inner">
					<div class="experience-columns">

						<!-- Professional column -->
						<div class="experience-col experience-col--professional">
							<h3 class="experience-col-title experience-col-title--professional">Professional</h3>
							<div class="experience-logo-stack">
								{professionalExperienceItems.map((item) => (
									<div class="experience-logo-item" tabindex="0">
										<img
											class:list={['experience-logo-img', 'experience-logo-img--light', item.logoClass]}
											src={item.logoLight}
											alt={item.logoAlt}
											loading="lazy"
										/>
										<img
											class:list={['experience-logo-img', 'experience-logo-img--dark', item.logoClass]}
											src={item.logoDark}
											alt=""
											aria-hidden="true"
											loading="lazy"
										/>
										<div class="experience-logo-hover" aria-hidden="true">
											<p class="experience-brand-name">{item.title}</p>
											<p class="experience-brand-role">{item.label}</p>
											{item.dates && <p class="experience-brand-detail">{item.dates}</p>}
											{item.location && <p class="experience-brand-detail">{item.location}</p>}
											<p class="experience-brand-copy">{item.body}</p>
											{item.links && item.links.map((link) => (
												<a href={link.url} target="_blank" rel="noreferrer" class="proof-link">
													{link.label}
												</a>
											))}
										</div>
									</div>
								))}
							</div>
						</div>

						<!-- Vertical divider -->
						<div class="experience-col-divider" aria-hidden="true"></div>

						<!-- Education column -->
						<div class="experience-col experience-col--education">
							<h3 class="experience-col-title experience-col-title--education">Education</h3>
							<div class="experience-logo-stack">
								{educationExperienceItems.map((item) => (
									<div class="experience-logo-item" tabindex="0">
										<img
											class:list={['experience-logo-img', 'experience-logo-img--light', item.logoClass]}
											src={item.logoLight}
											alt={item.logoAlt}
											loading="lazy"
										/>
										<img
											class:list={['experience-logo-img', 'experience-logo-img--dark', item.logoClass]}
											src={item.logoDark}
											alt=""
											aria-hidden="true"
											loading="lazy"
										/>
										<div class="experience-logo-hover" aria-hidden="true">
											<p class="experience-brand-name">{item.title}</p>
											<p class="experience-brand-role">{item.label}</p>
