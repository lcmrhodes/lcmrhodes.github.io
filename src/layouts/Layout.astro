---
interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = 'Luke Rhodes | Visualisation, Product, and Research Software',
	description = 'Luke Rhodes builds interactive visualisations, recommendation tools, and research software that make complex systems easier to understand and use.',
	image = '/favicon.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical.toString()} />
		<link rel="alternate" type="text/plain" href="/llms.txt" title="AI-readable portfolio guidance" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical.toString()} />
		<meta property="og:image" content={new URL(image, Astro.site).toString()} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="theme-color" content="#2d7f7a" />
		<script is:inline>
			const getBrowserTimeTheme = () => {
				const hour = new Date().getHours();
				return hour >= 7 && hour < 19 ? 'light' : 'dark';
			};
			let savedThemeOverride = null;
			let savedWeatherOverride = null;
			let autoEnvironment = null;
			try {
				savedThemeOverride = localStorage.getItem('portfolio-theme-override');
				savedWeatherOverride = localStorage.getItem('portfolio-weather-override');
				autoEnvironment = JSON.parse(localStorage.getItem('portfolio-auto-environment') || 'null');
			} catch {}
			if (savedThemeOverride === 'dark' || savedThemeOverride === 'light') {
				document.documentElement.dataset.theme = savedThemeOverride;
			} else if (
				autoEnvironment &&
				autoEnvironment.expires > Date.now() &&
				(autoEnvironment.theme === 'dark' || autoEnvironment.theme === 'light')
			) {
				document.documentElement.dataset.theme = autoEnvironment.theme;
			} else {
				document.documentElement.dataset.theme = getBrowserTimeTheme();
			}
			const validWeather = ['off', 'rain', 'clouds', 'snow', 'overcast'];
			if (savedWeatherOverride && validWeather.includes(savedWeatherOverride)) {
				document.documentElement.dataset.weather = savedWeatherOverride;
			} else if (
				autoEnvironment &&
				autoEnvironment.expires > Date.now() &&
				validWeather.includes(autoEnvironment.weather)
			) {
				document.documentElement.dataset.weather = autoEnvironment.weather;
			} else {
				document.documentElement.dataset.weather = 'off';
			}
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
